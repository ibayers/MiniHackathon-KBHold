# URL frontend kamu di Vercel (untuk generate QR)
# Contoh: https://kbhold.vercel.app
FRONTEND_URL=https://nama-app-kamu.vercel.app

# URL ngrok yang tunnel ke Flask lokal (untuk di-embed di QR sebagai ?backend=)
# Jalankan: ngrok http 5000
# Contoh: https://xxxx-xx-xx-xx.ngrok-free.app
BACKEND_URL=https://xxxx-xx-xx.ngrok-free.app
